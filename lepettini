  opacity: .96;
}

@keyframes fall{
  to{
    transform: translate3d(var(--drift, 0px), 110vh, 0) rotate(var(--rot, 180deg));
  }
}
@keyframes sway{
  from{ margin-left: -14px; }
  to  { margin-left:  14px; }
}
@keyframes glow{
  0%,100%{
    filter: drop-shadow(0 0 6px rgba(13,110,253,.35)) blur(.25px);
    opacity: .85;
  }
  50%{
    filter: drop-shadow(0 0 18px rgba(120,185,255,.55)) blur(.2px);
    opacity: .95;
  }
}

