  top: -10vh;
  width: 8px;
  height: 8px;
  border-radius: 50%;

  /* BLUE (#be16ee) */
  background: radial-gradient(
    circle at 30% 30%,
    #be16ee 0 25%,
    #be16ee 35%,
    #be16ee 55%,
    #be16ee 72%
  );

  filter: drop-shadow(0 0 10px rgba(13,110,253,.40)) blur(.25px);
  opacity: .92;

  will-change: transform, opacity, filter;
  animation:
    fall var(--dur, 12s) linear var(--delay, 0s) infinite,
    sway var(--sway, 6s) ease-in-out var(--delay, 0s) infinite alternate,
    glow 2.2s ease-in-out infinite alternate;
}

.snowflake.-sm{
  width: 4px;
  height: 4px;
